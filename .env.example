# Скопируйте этот файл в .env и заполните значения

# Токен бота от @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ID канала (например: -1001234567890 или @your_channel)
CHAT_ID=@your_channel_username

# Ключ API (достаточно одного — DeepSeek приоритетнее)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENAI_API_KEY=

# Интервал публикаций в часах (2 = каждые 2 часа: 00:00, 02:00, 04:00...)
POST_INTERVAL_HOURS=2

# Часовой пояс (обязательно Europe/Moscow на Railway)
TZ=Europe/Moscow

# Прокси — только для локального запуска в России (на Railway не нужен)
# TELEGRAM_PROXY=http://127.0.0.1:7890
TELEGRAM_PROXY=
# PROXY=http://127.0.0.1:7890
PROXY=

# Отключить проверку SSL (только если без прокси не работает). true/false
SSL_VERIFY=true
